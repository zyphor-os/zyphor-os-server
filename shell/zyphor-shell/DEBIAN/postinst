#!/bin/sh
# postinst - zyshell post-installation script
# Appends a zyshell launcher block to ~/.bashrc and/or ~/.zshrc
# so zyshell starts automatically in interactive login shells.

set -e

ZYSHELL_BIN="/usr/bin/zyshell"
MARKER="# >>> zyshell >>>"
MARKER_END="# <<< zyshell <<<"

BLOCK=$(cat <<'EOF'
# >>> zyshell >>>
# Launch zyshell (Zyphor OS Shell) for interactive non-zyshell sessions
if [ -x "/usr/bin/zyshell" ]; then
    case "$-" in
        *i*)
            # Only launch if we're not already inside zyshell
            if [ -z "$ZYSHELL_ACTIVE" ]; then
                export ZYSHELL_ACTIVE=1
                exec /usr/bin/zyshell
            fi
            ;;
    esac
fi
# <<< zyshell <<<
EOF
)

# ── Helper: append block to a rc file if not already present ─────────────────
append_to_rc() {
    RC_FILE="$1"

    # Only touch the file if it exists (don't create .zshrc on a bash-only system)
    if [ ! -f "$RC_FILE" ]; then
        return
    fi

    # Check if the marker is already there
    if grep -qF "$MARKER" "$RC_FILE" 2>/dev/null; then
        echo "zyshell: block already present in $RC_FILE, skipping."
        return
    fi

    # Append with a leading blank line for readability
    printf '\n%s\n' "$BLOCK" >> "$RC_FILE"
    echo "zyshell: launcher block appended to $RC_FILE"
}

# ── Determine the target user ─────────────────────────────────────────────────
# When run by dpkg, SUDO_USER or the invoking user is the real user.
if [ -n "$SUDO_USER" ]; then
    TARGET_USER="$SUDO_USER"
else
    TARGET_USER="$(logname 2>/dev/null || echo "$USER")"
fi

TARGET_HOME=$(getent passwd "$TARGET_USER" 2>/dev/null | cut -d: -f6)
if [ -z "$TARGET_HOME" ]; then
    TARGET_HOME="$HOME"
fi

echo "zyshell: configuring for user '$TARGET_USER' (home: $TARGET_HOME)"

# ── Append to whichever rc files exist ───────────────────────────────────────
append_to_rc "$TARGET_HOME/.bashrc"
append_to_rc "$TARGET_HOME/.zshrc"

# ── Also handle root's rc files if installing as root ────────────────────────
if [ "$(id -u)" = "0" ] && [ "$TARGET_USER" != "root" ]; then
    append_to_rc "/root/.bashrc"
    append_to_rc "/root/.zshrc"
fi

echo "zyshell: installation complete. Open a new terminal to start zyshell."

exit 0
